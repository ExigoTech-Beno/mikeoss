# Azure AI Foundry
FOUNDRY_PROJECT_ENDPOINT=https://your-project.api.azureml.ms
FOUNDRY_MODEL_DEPLOYMENT=gpt-4o

# Azure PostgreSQL Flexible Server
POSTGRES_DSN=postgresql://mikeadmin:your-password@mike-postgres.postgres.database.azure.com/mikedb?sslmode=require

# Azure Blob Storage
BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=mikestorage;AccountKey=your-key;EndpointSuffix=core.windows.net
BLOB_CONTAINER=mike

# Entra External ID
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-backend-app-client-id

# App
FRONTEND_URL=http://localhost:3000
PORT=8000
